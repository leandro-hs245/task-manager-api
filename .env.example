# PostgreSQL (sync URL for local Alembic: use postgresql+psycopg, same user/pass/db)
DATABASE_URL=postgresql+asyncpg://app:app@localhost:5432/appdb
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=appdb
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# In Docker, use: postgresql+asyncpg://app:app@db:5432/appdb

# Auth / JWT
SECRET_KEY=change-me-in-production-min-32-chars-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# API
CORS_ALLOW_ORIGINS=*

# SQL logging (true/false)
# SQLALCHEMY_ECHO=false
